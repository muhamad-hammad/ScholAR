# Copy this file to .env and fill in your values. Never commit .env itself.

# ── Hugging Face ──────────────────────────────────────────────────────────────
HUGGINGFACEHUB_API_TOKEN="hf_..."

# ── LangSmith (optional — for tracing) ───────────────────────────────────────
LANGSMITH_API_KEY="lsv2_..."
LANGSMITH_TRACING="true"

# ── LLM provider selection ────────────────────────────────────────────────────
# Supported: huggingface (default), openai, google, groq, openrouter, grok
LLM_PROVIDER="openai"

# Provider-specific API keys (only set the one matching LLM_PROVIDER)
OPENAI_API_KEY="sk-..."
GOOGLE_API_KEY="AIza..."
GROQ_API_KEY="gsk_..."
OPENROUTER_API_KEY="sk-or-..."
XAI_API_KEY="xai-..."

# ── Model identifiers ─────────────────────────────────────────────────────────
LLM_MODEL_ID="gpt-4o-mini"
EMBEDDING_MODEL_ID="BAAI/bge-base-en-v1.5"

# ── Paths ─────────────────────────────────────────────────────────────────────
PDF_INPUT_PATH="./data/research_paper.pdf"
CHROMA_PERSIST_DIR="./.chroma"

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=1024
CHUNK_OVERLAP=128

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVER_TOP_K=4
RETRIEVER_SCORE_THRESHOLD=0.0

# ── Generation limits ─────────────────────────────────────────────────────────
SUMMARY_MAX_CHARS=12000
EMBED_BATCH_SIZE=64
LLM_TIMEOUT_SECONDS=120
