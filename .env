# Environment configuration for Research RAG project
# NOTE: Replace placeholder values with your actual tokens/IDs when ready.

# Token used to download models and (optionally) access rate-limited HF endpoints
HUGGINGFACEHUB_API_TOKEN="YOUR_HF_ACCESS_TOKEN"

# LangSmith API key for free Developer-tier tracing and observability
LANGSMITH_API_KEY="YOUR_LANGSMITH_API_KEY"

# Enable LangSmith tracing (required for visual traces in LangSmith free tier)
LANGSMITH_TRACING="true"

# Model identifiers to use with Hugging Face / local pipeline
# Example LLM: meta-llama/Meta-Llama-3-8B-Instruct (or another locally-available instruct model)
LLM_MODEL_ID="huggingface_llm_model_id"

# Embedding model identifier (recommended: a free BGE or E5 family model)
EMBEDDING_MODEL_ID="huggingface_embedding_model_id"

# Path to the input PDF research paper (used by ingestion pipeline)
PDF_INPUT_PATH="./data/research_paper.pdf"

# ChromaDB persistence directory (optional override)
CHROMA_PERSIST_DIR="./.chroma"

# Chunking parameters (token-based) — tune based on chosen LLM's context window
CHUNK_SIZE=1024
CHUNK_OVERLAP=128

# Retriever configuration
RETRIEVER_TOP_K=4
